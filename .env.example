# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=gymwear
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Application URLs (used by Prisma / settings)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gymwear
REDIS_URL=redis://localhost:6379/0

# AI model settings
MODEL_NAME=distilgpt2
DEVICE_MAP_AUTO=false
MAX_TOKENS=120
