# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=gymwear
POSTGRES_PORT=5442

# Redis
REDIS_PORT=6380

# Application URLs (used by Prisma / settings)
DATABASE_URL=postgresql://postgres:postgres@localhost:5442/gymwear
REDIS_URL=redis://localhost:6380/0

# AI model settings
MODEL_NAME=distilgpt2
DEVICE_MAP_AUTO=false
MAX_TOKENS=120

# Gemini (optional)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash-latest

# CORS
# Example: ALLOWED_ORIGINS=["http://localhost:3000","https://yourdomain.com"]
ALLOWED_ORIGINS=["*"]
